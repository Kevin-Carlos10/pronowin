<%- include('layout_top', {page:'users'}) %>

<style>
/* ── Modals ──────────────────────────────────────────────────────────────── */
.ud-modal { display:none; position:fixed; inset:0; background:rgba(0,0,0,.6); backdrop-filter:blur(4px); z-index:200; align-items:center; justify-content:center; }
.ud-modal-box { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:1.75rem; width:min(96vw,480px); animation:slideUp .25s ease; }
@keyframes slideUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:none; } }
.ud-modal-title { font-size:1rem; font-weight:700; margin-bottom:1.1rem; }

/* ── Avatar ──────────────────────────────────────────────────────────────── */
.ud-avatar-wrap { position:relative; flex-shrink:0; }
.ud-avatar { width:64px; height:64px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.5rem; font-weight:800; }
.ud-avatar.premium { background:rgba(245,158,11,.15); color:var(--warning); }
.ud-avatar.normal  { background:var(--surface-d); color:var(--text-m); }
.ud-avatar.banned  { background:rgba(239,68,68,.15); color:var(--error); }
.ud-status-dot { position:absolute; bottom:2px; right:2px; width:14px; height:14px; border-radius:50%; border:2px solid var(--surface); }
.ud-status-dot.active   { background:var(--success); }
.ud-status-dot.inactive { background:var(--error); }
.ud-status-dot.banned   { background:var(--error); animation:pulse-live 2s ease-in-out infinite; }

/* ── Header user ─────────────────────────────────────────────────────────── */
.ud-header { display:flex; align-items:flex-start; gap:1rem; margin-bottom:1.25rem; flex-wrap:wrap; }
.ud-header-info { flex:1; min-width:0; }
.ud-name { font-size:1.3rem; font-weight:800; line-height:1.1; }
.ud-handle { font-size:.82rem; color:var(--text-m); margin-top:.2rem; }
.ud-id-row { display:flex; align-items:center; gap:.4rem; margin-top:.3rem; }
.ud-id { font-size:.72rem; color:var(--text-dim); font-family:monospace; background:var(--surface-d); padding:.15rem .45rem; border-radius:4px; }
.ud-copy-btn { background:none; border:none; cursor:pointer; color:var(--text-dim); font-size:.75rem; padding:.1rem .3rem; border-radius:4px; transition:all .15s; }
.ud-copy-btn:hover { background:var(--surface-h); color:var(--primary); }

/* ── Onglets ─────────────────────────────────────────────────────────────── */
.ud-tabs { display:flex; gap:0; border-bottom:1px solid var(--border); margin-bottom:1.25rem; overflow-x:auto; }
.ud-tab  { padding:.6rem 1.1rem; font-size:.83rem; font-weight:600; color:var(--text-m); border-bottom:2px solid transparent; cursor:pointer; white-space:nowrap; transition:color .15s, border-color .15s; background:none; border-top:none; border-left:none; border-right:none; font-family:inherit; }
.ud-tab:hover   { color:var(--text); }
.ud-tab.active  { color:var(--primary); border-bottom-color:var(--primary); }
.ud-panel       { display:none; }
.ud-panel.active { display:block; }

/* ── Info rows ───────────────────────────────────────────────────────────── */
.ud-row { display:flex; justify-content:space-between; align-items:center; padding:.55rem 0; border-bottom:1px solid var(--border); gap:.5rem; }
.ud-row:last-child { border-bottom:0; }
.ud-row-lbl { font-size:.8rem; color:var(--text-m); flex-shrink:0; }
.ud-row-val { font-size:.83rem; font-weight:500; color:var(--text); text-align:right; word-break:break-all; }
.ud-row-val.primary { color:var(--primary); }
.ud-row-val.success { color:var(--success); }
.ud-row-val.error   { color:var(--error); }
.ud-row-val.purple  { color:#A78BFA; }

/* ── Stats mini ──────────────────────────────────────────────────────────── */
.ud-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:.6rem; margin-bottom:1rem; }
.ud-stat  { background:var(--surface-d); border-radius:var(--radius-s); padding:.65rem .75rem; text-align:center; }
.ud-stat .v { font-size:1.2rem; font-weight:800; line-height:1; }
.ud-stat .l { font-size:.68rem; color:var(--text-dim); text-transform:uppercase; letter-spacing:.04em; margin-top:.2rem; }

/* ── Actions sidebar ─────────────────────────────────────────────────────── */
.ud-action-section { margin-bottom:.9rem; padding-bottom:.9rem; border-bottom:1px solid var(--border); }
.ud-action-section:last-child { margin-bottom:0; padding-bottom:0; border-bottom:0; }
.ud-action-title { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-dim); margin-bottom:.6rem; }
.ud-action-btns  { display:flex; flex-direction:column; gap:.4rem; }

/* ── Ban info box ────────────────────────────────────────────────────────── */
.ud-ban-box { background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.2); border-radius:var(--radius-s); padding:.75rem .9rem; margin-bottom:.75rem; font-size:.8rem; }
.ud-ban-box .reason { font-weight:600; color:var(--text); margin-bottom:.25rem; }
.ud-ban-box .meta   { color:var(--text-dim); line-height:1.5; }

/* ── Premium box ─────────────────────────────────────────────────────────── */
.ud-premium-box { background:rgba(245,158,11,.08); border:1px solid rgba(245,158,11,.2); border-radius:var(--radius-s); padding:.75rem .9rem; margin-bottom:.75rem; font-size:.83rem; color:var(--warning); font-weight:600; }

/* ── Layout ──────────────────────────────────────────────────────────────── */
.ud-layout { display:grid; grid-template-columns:1fr 300px; gap:1rem; align-items:start; }
@media (max-width:900px) { .ud-layout { grid-template-columns:1fr; } }
</style>

<!-- ── Modals ───────────────────────────────────────────────────────────── -->
<div class="ud-modal" id="modal-ban">
  <div class="ud-modal-box">
    <div class="ud-modal-title" style="color:var(--error)">🚫 Bannir <%= user.pseudo %></div>
    <form method="POST" action="/admin/users/<%= user.id %>/ban">
      <input type="hidden" name="pseudo" value="<%= user.pseudo %>">
      <div class="form-group" style="margin-bottom:.9rem">
        <label>Raison <span style="color:var(--error)">*</span></label>
        <textarea class="input" name="reason" rows="3" placeholder="Ex : Arnaque, comportement abusif, fraude…" required></textarea>
      </div>
      <div class="form-group" style="margin-bottom:1.25rem">
        <label>Durée</label>
        <select class="input" name="duration_days">
          <option value="1">1 jour</option>
          <option value="3">3 jours</option>
          <option value="7" selected>7 jours</option>
          <option value="14">14 jours</option>
          <option value="30">30 jours</option>
          <option value="90">90 jours</option>
          <option value="0">🚫 Permanent</option>
        </select>
      </div>
      <div style="display:flex;gap:.6rem;justify-content:flex-end">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-ban')">Annuler</button>
        <button type="submit" class="btn btn-danger">🚫 Bannir</button>
      </div>
    </form>
  </div>
</div>

<div class="ud-modal" id="modal-notif">
  <div class="ud-modal-box">
    <div class="ud-modal-title">📱 Envoyer une notification</div>
    <form method="POST" action="/admin/users/<%= user.id %>/notify">
      <div class="form-group" style="margin-bottom:.9rem"><label>Titre</label><input class="input" type="text" name="title" required placeholder="Ex : Votre dépôt a été validé"></div>
      <div class="form-group" style="margin-bottom:1.25rem"><label>Message</label><textarea class="input" name="body" rows="3" required placeholder="Contenu de la notification…"></textarea></div>
      <div style="display:flex;gap:.6rem;justify-content:flex-end">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-notif')">Annuler</button>
        <button type="submit" class="btn btn-primary">📤 Envoyer</button>
      </div>
    </form>
  </div>
</div>

<div class="ud-modal" id="modal-pseudo">
  <div class="ud-modal-box">
    <div class="ud-modal-title">✏️ Modifier le pseudo</div>
    <form method="POST" action="/admin/users/<%= user.id %>/pseudo">
      <div class="form-group" style="margin-bottom:1.25rem"><label>Nouveau pseudo</label><input class="input" type="text" name="pseudo" value="<%= user.pseudo %>" required minlength="3"></div>
      <div style="display:flex;gap:.6rem;justify-content:flex-end">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-pseudo')">Annuler</button>
        <button type="submit" class="btn btn-primary">Sauvegarder</button>
      </div>
    </form>
  </div>
</div>

<!-- ── Topbar ───────────────────────────────────────────────────────────── -->
<div class="topbar">
  <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
    <a href="/admin/users" style="color:var(--text-dim);font-size:.82rem;text-decoration:none">← Utilisateurs</a>
    <span style="color:var(--border)">/</span>
    <h2 style="margin:0"><%= user.full_name || user.pseudo %></h2>
    <span class="badge <%= user.isActive ? 'badge-ok' : 'badge-err' %>"><%= user.isActive ? '✓ Actif' : '✗ Suspendu' %></span>
    <% if(user.is_premium) { %><span class="badge badge-warn">👑 Premium</span><% } %>
    <% if(typeof activeBan !== 'undefined' && activeBan) { %><span class="badge badge-err">🚫 Banni</span><% } %>
  </div>
  <a href="/admin/users/<%= user.id %>" class="btn btn-outline btn-sm" title="Recharger">🔄</a>
</div>

<!-- ── Layout ───────────────────────────────────────────────────────────── -->
<div class="ud-layout">

  <!-- Colonne principale -->
  <div>

    <!-- Card identité + onglets -->
    <div class="card" style="margin-bottom:1rem">

      <!-- Header avatar -->
      <div class="ud-header">
        <div class="ud-avatar-wrap">
          <div class="ud-avatar <%= (typeof activeBan!=='undefined'&&activeBan)?'banned':user.is_premium?'premium':'normal' %>">
            <%= (user.pseudo||'?')[0].toUpperCase() %>
          </div>
          <div class="ud-status-dot <%= (typeof activeBan!=='undefined'&&activeBan)?'banned':user.isActive?'active':'inactive' %>"></div>
        </div>
        <div class="ud-header-info">
          <div class="ud-name"><%= user.full_name || user.pseudo %></div>
          <% if(user.full_name) { %><div class="ud-handle">@<%= user.pseudo %></div><% } %>
          <div class="ud-id-row">
            <span class="ud-id" id="user-id-display"><%= user.id %></span>
            <button class="ud-copy-btn" onclick="copyId()" title="Copier l'ID">📋</button>
            <span id="copy-confirm" style="font-size:.7rem;color:var(--success);display:none">✓ Copié</span>
          </div>
        </div>
        <!-- Stats rapides -->
        <div class="ud-stats" style="min-width:200px">
          <div class="ud-stat">
            <div class="v"><%= transactions ? transactions.length : 0 %></div>
            <div class="l">TX</div>
          </div>
          <div class="ud-stat">
            <div class="v" style="color:var(--warning)"><%= (user.days_left&&user.is_premium) ? user.days_left+'j' : '—' %></div>
            <div class="l">Premium</div>
          </div>
          <div class="ud-stat">
            <div class="v" style="color:var(--success)"><%= (user.referralEarnings||0) > 0 ? ((user.referralEarnings/1000).toFixed(0)+'k') : (referrals ? referrals.length : 0) %></div>
            <div class="l"><%= (user.referralEarnings||0) > 0 ? 'FCFA' : 'Filleuls' %></div>
          </div>
        </div>
      </div>

      <!-- Onglets -->
      <div class="ud-tabs">
        <button class="ud-tab active" onclick="switchTab('tab-info', this)">👤 Informations</button>
        <button class="ud-tab" onclick="switchTab('tab-tx', this)">💰 Transactions (<%= transactions ? transactions.length : 0 %>)</button>
        <% if(subscriptions && subscriptions.length > 0) { %>
        <button class="ud-tab" onclick="switchTab('tab-subs', this)">👑 Abonnements (<%= subscriptions.length %>)</button>
        <% } %>
        <% if(referrals && referrals.length > 0) { %>
        <button class="ud-tab" onclick="switchTab('tab-refs', this)">👥 Filleuls (<%= referrals.length %>)</button>
        <% } %>
      </div>

      <!-- Onglet : Informations -->
      <div class="ud-panel active" id="tab-info">
        <% function row(lbl, val, cls) { %>
        <div class="ud-row">
          <span class="ud-row-lbl"><%= lbl %></span>
          <span class="ud-row-val <%= cls||'' %>"><%= val || '—' %></span>
        </div>
        <% } %>
        <% row('Prénom',    user.firstName) %>
        <% row('Nom',       user.lastName) %>
        <% if(user.birthDate) {
             const bd = new Date(user.birthDate);
             const age = Math.floor((Date.now()-bd.getTime())/(365.25*86400000));
             row('Naissance', bd.toLocaleDateString('fr-FR')+' ('+age+' ans)');
           } else { row('Naissance', '—'); }
        %>
        <% row('Téléphone', user.phoneNumber) %>
        <% row('Email',     user.email) %>
        <% row('Pays',      user.countryCode) %>
        <% row('ID 1xBet',  user.xbetId || '—', 'primary') %>
        <% row('Code parrainage', user.referralCode, 'purple') %>
        <% row('Gains parrainage', (user.referralEarnings||0).toLocaleString()+' FCFA', 'success') %>
        <% row('Inscrit le', new Date(user.createdAt).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})) %>
        <% row('Dernière connexion', user.lastLoginAt ? new Date(user.lastLoginAt).toLocaleDateString('fr-FR',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) : 'Jamais') %>
        <% row('Token FCM', user.fcmToken ? '✓ Enregistré' : '✗ Absent', user.fcmToken ? 'success' : 'error') %>
      </div>

      <!-- Onglet : Transactions -->
      <div class="ud-panel" id="tab-tx">
        <% if(!transactions || transactions.length === 0) { %>
        <p class="empty" style="padding:1.5rem 0">Aucune transaction enregistrée.</p>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Type</th><th>Montant</th><th>Méthode</th><th>Statut</th><th>Date</th></tr></thead>
            <tbody>
            <% transactions.forEach(tx => { %>
            <tr>
              <td><span class="badge <%= tx.type==='deposit'?'badge-ok':'badge-warn' %>"><%= tx.type==='deposit'?'⬇️ Dépôt':'⬆️ Retrait' %></span></td>
              <td style="font-weight:700"><%= (tx.amount||0).toLocaleString() %> FCFA</td>
              <td style="color:var(--text-m);font-size:.78rem"><%= (tx.paymentMethod||'').replace(/_/g,' ') || '—' %></td>
              <td><span class="badge <%= tx.status==='completed'?'badge-ok':tx.status==='rejected'?'badge-err':'badge-warn' %>"><%= tx.status %></span></td>
              <td style="color:var(--text-dim);font-size:.78rem"><%= new Date(tx.createdAt).toLocaleDateString('fr-FR',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %></td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- Onglet : Abonnements -->
      <% if(subscriptions && subscriptions.length > 0) { %>
      <div class="ud-panel" id="tab-subs">
        <div class="table-wrap">
          <table>
            <thead><tr><th>Plan</th><th>Statut</th><th>Début</th><th>Fin</th><th>Source</th></tr></thead>
            <tbody>
            <% subscriptions.forEach(sub => { %>
            <tr>
              <td><span class="badge badge-warn"><%= sub.plan || sub.subscriptionPlan || 'Premium' %></span></td>
              <td><span class="badge <%= sub.status==='active'?'badge-ok':'badge-err' %>"><%= sub.status || '—' %></span></td>
              <td style="font-size:.78rem;color:var(--text-m)"><%= sub.startDate ? new Date(sub.startDate).toLocaleDateString('fr-FR') : '—' %></td>
              <td style="font-size:.78rem;color:var(--text-m)"><%= sub.endDate ? new Date(sub.endDate).toLocaleDateString('fr-FR') : '—' %></td>
              <td style="font-size:.78rem;color:var(--text-dim)"><%= sub.source || '—' %></td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- Onglet : Filleuls -->
      <% if(referrals && referrals.length > 0) { %>
      <div class="ud-panel" id="tab-refs">
        <div class="table-wrap">
          <table>
            <thead><tr><th>Filleul</th><th>Téléphone</th><th>Plan</th><th>Niveau</th><th>Commission</th></tr></thead>
            <tbody>
            <% referrals.forEach(r => { %>
            <tr>
              <td>
                <a href="/admin/users/<%= r.referred.id ?? '' %>" style="font-weight:600;color:var(--text);text-decoration:none"><%= r.referred.pseudo %></a>
              </td>
              <td style="color:var(--text-m);font-size:.78rem"><%= r.referred.phoneNumber %></td>
              <td><span class="badge <%= r.referred.subscriptionPlan==='premium'?'badge-warn':'badge-info' %>"><%= r.referred.subscriptionPlan %></span></td>
              <td style="text-align:center;font-weight:600">N<%= r.level %></td>
              <td style="color:var(--success);font-weight:700"><%= (r.commissionAmount||0).toLocaleString() %> FCFA</td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

    </div><!-- /card -->
  </div><!-- /col principale -->

  <!-- Colonne actions -->
  <div>
    <div class="card">

      <!-- Premium -->
      <div class="ud-action-section">
        <div class="ud-action-title">👑 Abonnement Premium</div>
        <% if(user.is_premium) { %>
        <div class="ud-premium-box">
          Premium actif — <%= user.days_left %> jour<%= user.days_left > 1 ? 's' : '' %> restant<%= user.days_left > 1 ? 's' : '' %>
        </div>
        <form method="POST" action="/admin/users/<%= user.id %>/revoke-premium">
          <button type="submit" class="btn btn-danger btn-sm" style="width:100%"
            onclick="return confirm('Révoquer le Premium de <%= user.pseudo %> ?')">✗ Révoquer le Premium</button>
        </form>
        <% } else { %>
        <form method="POST" action="/admin/users/<%= user.id %>/premium" style="display:flex;gap:.5rem;align-items:flex-end">
          <div style="flex:1">
            <label style="font-size:.72rem;color:var(--text-dim);display:block;margin-bottom:.3rem">Durée (jours)</label>
            <input class="input" type="number" name="duration_days" value="30" min="1" max="365">
          </div>
          <button type="submit" class="btn btn-primary btn-sm">👑 Activer</button>
        </form>
        <% } %>
      </div>

      <!-- Suspension -->
      <div class="ud-action-section">
        <div class="ud-action-title"><%= user.isActive ? '🔒 Suspension' : '🔓 Réactivation' %></div>
        <form method="POST" action="/admin/users/<%= user.id %>/suspend">
          <input type="hidden" name="suspend" value="<%= user.isActive ? 'true' : 'false' %>">
          <% if(user.isActive) { %>
          <input class="input" type="text" name="reason" placeholder="Raison (optionnelle)…" style="margin-bottom:.5rem;font-size:.82rem">
          <% } %>
          <button type="submit" class="btn <%= user.isActive ? 'btn-danger' : 'btn-success' %> btn-sm" style="width:100%"
            onclick="return confirm('<%= user.isActive ? 'Suspendre' : 'Réactiver' %> ce compte ?')">
            <%= user.isActive ? '🔒 Suspendre' : '🔓 Réactiver' %>
          </button>
        </form>
      </div>

      <!-- Bannissement -->
      <% if(hasPerm('users','write')) { %>
      <div class="ud-action-section">
        <div class="ud-action-title">🚫 Bannissement</div>
        <% if(typeof activeBan !== 'undefined' && activeBan) { %>
        <div class="ud-ban-box">
          <div class="reason">« <%= activeBan.reason %> »</div>
          <div class="meta">
            Par <strong><%= activeBan.bannedBy %></strong> · <%= new Date(activeBan.bannedAt).toLocaleDateString('fr-FR') %>
            <% if(activeBan.expiresAt) { %> · expire le <strong><%= new Date(activeBan.expiresAt).toLocaleDateString('fr-FR') %></strong><% } else { %> · <strong>Permanent</strong><% } %>
          </div>
        </div>
        <form method="POST" action="/admin/users/<%= user.id %>/unban">
          <input type="hidden" name="pseudo" value="<%= user.pseudo %>">
          <input class="input" type="text" name="unban_reason" placeholder="Raison du débannissement…" style="margin-bottom:.5rem;font-size:.82rem">
          <button type="submit" class="btn btn-success btn-sm" style="width:100%">🔓 Débannir</button>
        </form>
        <% } else { %>
        <button onclick="openModal('modal-ban')" class="btn btn-danger btn-sm" style="width:100%">🚫 Bannir cet utilisateur</button>
        <% } %>
      </div>
      <% } %>

      <!-- Actions rapides -->
      <div class="ud-action-section">
        <div class="ud-action-title">⚡ Actions rapides</div>
        <div class="ud-action-btns">
          <button onclick="openModal('modal-notif')" class="btn btn-outline btn-sm" style="justify-content:flex-start">📱 Envoyer une notification</button>
          <button onclick="openModal('modal-pseudo')" class="btn btn-outline btn-sm" style="justify-content:flex-start">✏️ Modifier le pseudo</button>
          <a href="/admin/historique?search=<%= encodeURIComponent(user.phoneNumber||user.pseudo) %>" class="btn btn-outline btn-sm" style="justify-content:flex-start">📋 Voir l'historique</a>
          <% if(isMain) { %>
          <a href="/admin/bans?search=<%= encodeURIComponent(user.pseudo) %>" class="btn btn-outline btn-sm" style="justify-content:flex-start">🚫 Historique bans</a>
          <% } %>
        </div>
      </div>

    </div><!-- /card actions -->
  </div><!-- /col actions -->
</div><!-- /layout -->

<script>
/* ── Onglets ── */
function switchTab(id, btn) {
  document.querySelectorAll('.ud-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.ud-tab').forEach(b => b.classList.remove('active'));
  const panel = document.getElementById(id);
  if (panel) panel.classList.add('active');
  if (btn) btn.classList.add('active');
}

/* ── Modals ── */
function openModal(id) {
  const m = document.getElementById(id);
  if (m) { m.style.display = 'flex'; }
}
function closeModal(id) {
  const m = document.getElementById(id);
  if (m) { m.style.display = 'none'; }
}
document.querySelectorAll('.ud-modal').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) m.style.display = 'none'; });
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.querySelectorAll('.ud-modal').forEach(m => m.style.display = 'none');
});

/* ── Copier ID ── */
function copyId() {
  const id = '<%= user.id %>';
  navigator.clipboard?.writeText(id).then(() => {
    const c = document.getElementById('copy-confirm');
    if (c) { c.style.display = 'inline'; setTimeout(() => c.style.display = 'none', 2000); }
  }).catch(() => {
    // fallback
    const el = document.createElement('textarea');
    el.value = id; document.body.appendChild(el); el.select();
    document.execCommand('copy'); document.body.removeChild(el);
    const c = document.getElementById('copy-confirm');
    if (c) { c.style.display = 'inline'; setTimeout(() => c.style.display = 'none', 2000); }
  });
}

/* ── Toasts succès / erreur ── */
document.addEventListener('DOMContentLoaded', function() {
  <% if(typeof success !== 'undefined' && success) { %>
  if (typeof showToast === 'function') showToast('<%= success.replace(/'/g, "\\'") %>', 'success');
  <% } %>
  <% if(typeof error !== 'undefined' && error) { %>
  if (typeof showToast === 'function') showToast('<%= error.replace(/'/g, "\\'") %>', 'error');
  <% } %>
});
</script>

