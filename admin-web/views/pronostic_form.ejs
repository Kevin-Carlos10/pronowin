<%- include('layout_top', {page:'pronostics'}) %>

<style>
/* ── Match preview ────────────────────────────────────────────────────────────── */
.match-preview {
  display:flex; align-items:center; justify-content:center;
  gap:1.5rem; padding:1.5rem 1rem;
}
.mp-team { text-align:center; flex:1; }
.mp-team img {
  width:64px; height:64px; border-radius:50%; object-fit:contain;
  background:var(--surface-d); margin-bottom:.5rem;
}
.mp-team .initial {
  width:64px; height:64px; border-radius:50%; background:var(--surface-d);
  display:flex; align-items:center; justify-content:center;
  font-size:1.5rem; font-weight:800; color:var(--text-m);
  margin:0 auto .5rem;
}
.mp-team .tname { font-size:.95rem; font-weight:700; line-height:1.3; }
.mp-sep { font-size:1.25rem; font-weight:800; color:var(--text-dim); flex-shrink:0; }
.mp-meta { text-align:center; margin-top:.75rem; padding-top:.75rem; border-top:1px solid var(--border); }

/* ── Étoiles ──────────────────────────────────────────────────────────────────── */
.stars { display:flex; gap:.25rem; margin-bottom:.5rem; }
.star {
  font-size:1.6rem; cursor:pointer; color:var(--border);
  transition:color .12s, transform .1s;
  line-height:1; user-select:none;
}
.star.active { color:var(--warning); transform:scale(1.1); }
.star:hover  { color:var(--warning); opacity:.7; }

/* ── Cotes grid ───────────────────────────────────────────────────────────────── */
.odds-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:.75rem; }
@media(max-width:640px){ .odds-grid { grid-template-columns:1fr 1fr; } }

/* ── Type pills ────────────────────────────────────────────────────────────────── */
.type-pills { display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:.75rem; }
.type-pill {
  padding:.35rem .75rem; border-radius:20px; font-size:.78rem; font-weight:600;
  background:var(--surface-d); border:1px solid var(--border); color:var(--text-m);
  cursor:pointer; transition:all .15s; white-space:nowrap;
}
.type-pill:hover, .type-pill.active { background:rgba(var(--primary-rgb),.12); border-color:var(--primary); color:var(--primary); }

/* ── Premium toggle ────────────────────────────────────────────────────────────── */
.vip-toggle {
  display:flex; align-items:center; gap:.75rem; padding:.75rem 1rem;
  background:var(--surface-d); border:1px solid var(--border);
  border-radius:var(--radius-s); cursor:pointer; transition:all .15s;
}
.vip-toggle:hover { border-color:var(--warning); }
.vip-toggle input { display:none; }
.vip-badge {
  display:flex; align-items:center; justify-content:center;
  width:36px; height:36px; border-radius:50%;
  background:rgba(245,158,11,.12); font-size:1.2rem; flex-shrink:0;
}
.vip-toggle .info { flex:1; }
.vip-toggle .info .t { font-size:.85rem; font-weight:700; color:var(--text); }
.vip-toggle .info .s { font-size:.75rem; color:var(--text-dim); margin-top:.1rem; }
.vip-toggle .checkmark { color:var(--text-dim); font-size:1.1rem; transition:color .15s; }
.vip-toggle.checked { border-color:var(--warning); }
.vip-toggle.checked .checkmark { color:var(--warning); }
.vip-toggle.checked .vip-badge { background:rgba(245,158,11,.2); }
</style>

<%
  const pro = match.pronostic ?? {};
  const homeInitial = (match.homeTeam||'?')[0].toUpperCase();
  const awayInitial = (match.awayTeam||'?')[0].toUpperCase();
  const matchDate   = new Date(match.matchDate);
  const dateStr     = matchDate.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  const timeStr     = matchDate.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  const isEdit      = !!pro.id;
%>

<div class="topbar">
  <div>
    <a href="/admin/pronostics" style="color:var(--text-dim);font-size:.82rem;text-decoration:none">← Retour aux matchs</a>
    <h2 style="margin-top:4px"><%= isEdit ? '✏️ Modifier' : '+ Créer' %> un pronostic</h2>
  </div>
  <% if(isEdit && pro.is_published) { %>
  <span class="badge badge-ok" style="font-size:.78rem">✅ Publié</span>
  <% } else if(isEdit) { %>
  <span class="badge badge-warn" style="font-size:.78rem">✏️ Brouillon</span>
  <% } %>
</div>

<% if(error){ %><div class="alert alert-error"><%= error %></div><% } %>

<style>@media(max-width:860px){ .pf-main-grid { grid-template-columns:1fr !important; } }</style>
<div class="pf-main-grid" style="display:grid;grid-template-columns:320px 1fr;gap:1rem;align-items:start">

  <!-- ── Colonne gauche : match info ──────────────────────────────────────────── -->
  <div>
    <div class="card">
      <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.85rem">
        <% if(match.leagueLogo){ %><img src="<%= match.leagueLogo %>" style="width:18px;height:18px;object-fit:contain" onerror="this.style.display='none'"><% } %>
        <span class="badge badge-info" style="font-size:.7rem"><%= match.league %></span>
      </div>

      <div class="match-preview">
        <div class="mp-team">
          <% if(match.homeTeamLogo){ %>
          <img src="<%= match.homeTeamLogo %>" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="initial" style="display:none"><%= homeInitial %></div>
          <% } else { %>
          <div class="initial"><%= homeInitial %></div>
          <% } %>
          <div class="tname"><%= match.homeTeam %></div>
        </div>
        <div class="mp-sep">VS</div>
        <div class="mp-team">
          <% if(match.awayTeamLogo){ %>
          <img src="<%= match.awayTeamLogo %>" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="initial" style="display:none"><%= awayInitial %></div>
          <% } else { %>
          <div class="initial"><%= awayInitial %></div>
          <% } %>
          <div class="tname"><%= match.awayTeam %></div>
        </div>
      </div>

      <div class="mp-meta">
        <div style="font-weight:700;margin-bottom:.25rem"><%= dateStr %></div>
        <div style="color:var(--text-dim);font-size:.82rem">⏰ Coup d'envoi à <strong><%= timeStr %></strong></div>
        <div style="font-size:.72rem;color:var(--text-dim);margin-top:.4rem;font-family:monospace">ID match : <%= match.id %></div>
      </div>
    </div>

    <% if(isEdit) { %>
    <div class="card" style="margin-top:.75rem;padding:.85rem 1rem">
      <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-dim);font-weight:700;margin-bottom:.6rem">Historique</div>
      <% if(pro.createdAt){ %><div style="font-size:.78rem;color:var(--text-m)">📝 Créé le <%= new Date(pro.createdAt).toLocaleDateString('fr-FR',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) %></div><% } %>
      <% if(pro.updatedAt){ %><div style="font-size:.78rem;color:var(--text-m);margin-top:.3rem">🔄 Modifié le <%= new Date(pro.updatedAt).toLocaleDateString('fr-FR',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) %></div><% } %>
      <% if(pro.publishedAt){ %><div style="font-size:.78rem;color:var(--success);margin-top:.3rem">🚀 Publié le <%= new Date(pro.publishedAt).toLocaleDateString('fr-FR',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) %></div><% } %>
    </div>
    <% } %>
  </div>

  <!-- ── Colonne droite : formulaire ──────────────────────────────────────────── -->
  <div class="card">
    <form method="POST" action="/admin/pronostics/edit/<%= match.id %>" id="pro-form">

      <!-- Type de pronostic -->
      <div class="form-group" style="margin-bottom:1.1rem">
        <label>Type de pronostic</label>
        <div class="type-pills" id="type-pills">
          <% const types = [
            {v:'win1',  l:'🏠 Victoire dom.'},
            {v:'draw',  l:'🤝 Match nul'},
            {v:'win2',  l:'✈️ Victoire ext.'},
            {v:'btts',  l:'⚽⚽ BTTS'},
            {v:'over25',l:'📈 +2.5 buts'},
            {v:'under25',l:'📉 -2.5 buts'},
            {v:'over35',l:'📈 +3.5 buts'},
            {v:'under35',l:'📉 -3.5 buts'},
          ]; %>
          <% types.forEach(t => { %>
          <div class="type-pill <%= (pro.prediction_type||'win1')===t.v?'active':'' %>"
               data-val="<%= t.v %>" onclick="setType('<%= t.v %>')"><%= t.l %></div>
          <% }) %>
        </div>
        <input type="hidden" name="prediction_type" id="type-input" value="<%= pro.prediction_type||'win1' %>">
      </div>

      <!-- Label affiché -->
      <div class="form-group" style="margin-bottom:1.1rem">
        <label>Label affiché <small style="font-weight:400;color:var(--text-dim)">(visible aux utilisateurs)</small></label>
        <input class="input" type="text" name="prediction_label" id="pred-label"
               value="<%= pro.prediction_label||'' %>" required
               placeholder="Ex : PSG gagne, +2.5 buts…">
      </div>

      <!-- Cotes -->
      <div class="form-group" style="margin-bottom:1.1rem">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem">
          <label style="margin:0">Cotes</label>
          <button type="button" id="btn-fetch-odds" onclick="fetchOdds()"
            style="display:flex;align-items:center;gap:.4rem;padding:.3rem .75rem;font-size:.78rem;
                   background:rgba(var(--primary-rgb),.12);border:1px solid var(--primary);
                   color:var(--primary);border-radius:8px;cursor:pointer;font-weight:600;transition:all .15s">
            <span id="odds-btn-icon">⚡</span> Récupérer les cotes
          </button>
        </div>
        <div id="odds-msg" style="display:none;font-size:.75rem;margin-bottom:.4rem;padding:.35rem .6rem;border-radius:6px"></div>
        <div class="odds-grid">
          <div>
            <div style="font-size:.7rem;color:var(--text-dim);margin-bottom:.3rem">1 (domicile)</div>
            <input class="input" type="number" name="odds_home" step="0.01" min="1" required
                   value="<%= pro.odds_home||'' %>" placeholder="1.80">
          </div>
          <div>
            <div style="font-size:.7rem;color:var(--text-dim);margin-bottom:.3rem">X (nul)</div>
            <input class="input" type="number" name="odds_draw" step="0.01" min="1" required
                   value="<%= pro.odds_draw||'' %>" placeholder="3.50">
          </div>
          <div>
            <div style="font-size:.7rem;color:var(--text-dim);margin-bottom:.3rem">2 (extérieur)</div>
            <input class="input" type="number" name="odds_away" step="0.01" min="1" required
                   value="<%= pro.odds_away||'' %>" placeholder="4.20">
          </div>
          <div>
            <div style="font-size:.7rem;color:var(--text-dim);margin-bottom:.3rem">⭐ Cote recommandée</div>
            <input class="input" type="number" name="odds_recommended" step="0.01" min="1" required
                   value="<%= pro.odds_recommended||'' %>" placeholder="1.80" id="odds-rec">
          </div>
        </div>
      </div>

      <!-- Confiance -->
      <div class="form-group" style="margin-bottom:1.1rem">
        <label>Niveau de confiance</label>
        <div class="stars" id="stars">
          <% for(let i=1;i<=5;i++){ %>
          <span class="star" data-v="<%= i %>" onclick="setStar(<%= i %>)">★</span>
          <% } %>
        </div>
        <div style="font-size:.75rem;color:var(--text-dim)" id="star-label">Confiance : 3/5</div>
        <input type="hidden" name="confidence_score" id="conf-input" value="<%= pro.confidence_score||3 %>">
      </div>

      <!-- Note analyste -->
      <div class="form-group" style="margin-bottom:1.1rem">
        <label>Note analyste <span class="badge badge-warn" style="font-size:.65rem;vertical-align:middle">👑 Premium</span></label>
        <textarea class="input" name="analyst_note" rows="4"
                  placeholder="Analyse détaillée du match, contexte, absents clés…"><%= pro.analyst_note||'' %></textarea>
      </div>

      <!-- VIP toggle -->
      <div class="form-group" style="margin-bottom:1.4rem">
        <div class="vip-toggle <%= (pro.is_premium)?'checked':'' %>" id="vip-toggle" onclick="toggleVip()">
          <div class="vip-badge">👑</div>
          <div class="info">
            <div class="t">Pronostic VIP</div>
            <div class="s">Réservé aux abonnés Premium uniquement</div>
          </div>
          <div class="checkmark" id="vip-check"><%= (pro.is_premium)?'✅':'○' %></div>
          <input type="checkbox" name="is_premium" id="is-premium" <%= (pro.is_premium)?'checked':'' %>>
        </div>
      </div>

      <!-- Boutons -->
      <div style="display:flex;gap:.75rem;flex-wrap:wrap">
        <button type="submit" name="publish" value="false" class="btn btn-outline">
          💾 Sauvegarder brouillon
        </button>
        <button type="submit" name="publish" value="true" class="btn btn-primary" onclick="setPublish(true)">
          🚀 Publier maintenant
        </button>
        <% if(isEdit && pro.is_published) { %>
        <button type="button" class="btn btn-danger btn-sm" style="margin-left:auto"
          onclick="askConfirm({icon:'🗑️',title:'Dépublier',msg:'Retirer ce pronostic de la liste publique ?',btnLabel:'Dépublier',btnClass:'btn-danger',onConfirm:()=>depublish()})">
          🗑️ Dépublier
        </button>
        <% } %>
      </div>

    </form>
  </div>
</div>

<script>
/* ── Étoiles ── */
const _initStar = parseInt(document.getElementById('conf-input').value) || 3;
setStar(_initStar);
function setStar(v) {
  document.getElementById('conf-input').value = v;
  document.querySelectorAll('.star').forEach((s, i) => s.classList.toggle('active', i < v));
  const labels = ['','Très faible','Faible','Moyen','Bon','Excellent'];
  document.getElementById('star-label').textContent = `Confiance : ${v}/5 — ${labels[v]||''}`;
}

/* ── Type pills ── */
const typeLabels = {
  win1: '<%= match.homeTeam %> gagne',
  draw: 'Match nul',
  win2: '<%= match.awayTeam %> gagne',
  btts: 'Les deux équipes marquent',
  over25: '+2.5 buts',
  under25: '-2.5 buts',
  over35: '+3.5 buts',
  under35: '-3.5 buts'
};
function setType(v) {
  document.getElementById('type-input').value = v;
  document.querySelectorAll('.type-pill').forEach(p => p.classList.toggle('active', p.dataset.val === v));
  const lbl = document.getElementById('pred-label');
  if (!lbl.value || typeLabels[document.getElementById('type-input')._prev] === lbl.value) {
    lbl.value = typeLabels[v] || '';
  }
  document.getElementById('type-input')._prev = v;
  // Auto-fill cote recommandée selon type
  const rec = document.getElementById('odds-rec');
  const map = { win1:'odds_home', win2:'odds_away', draw:'odds_draw' };
  if (map[v]) {
    const src = document.querySelector('[name="' + map[v] + '"]');
    if (src && src.value) rec.value = src.value;
  }
}
document.getElementById('type-input')._prev = document.getElementById('type-input').value;

/* ── VIP toggle ── */
function toggleVip() {
  const cb   = document.getElementById('is-premium');
  const tog  = document.getElementById('vip-toggle');
  const chk  = document.getElementById('vip-check');
  cb.checked = !cb.checked;
  tog.classList.toggle('checked', cb.checked);
  chk.textContent = cb.checked ? '✅' : '○';
}

/* ── Récupérer les cotes depuis The Odds API ── */
async function fetchOdds() {
  const btn  = document.getElementById('btn-fetch-odds');
  const icon = document.getElementById('odds-btn-icon');
  const msg  = document.getElementById('odds-msg');
  const matchId = '<%= match.id %>';

  btn.disabled = true;
  icon.textContent = '⏳';
  msg.style.display = 'none';

  try {
    const r = await fetch(`/admin/pronostics/edit/${matchId}/odds`, {
      credentials: 'include'
    });
    const data = await r.json();

    if (!r.ok) throw new Error(data.message || 'Erreur inconnue');

    // Remplir les 3 champs (pas la cote recommandée)
    document.querySelector('[name="odds_home"]').value = data.home.toFixed(2);
    document.querySelector('[name="odds_draw"]').value = data.draw.toFixed(2);
    document.querySelector('[name="odds_away"]').value = data.away.toFixed(2);

    // Auto-fill cote recommandée selon le type sélectionné
    const type = document.getElementById('type-input').value;
    const map  = { win1: data.home, win2: data.away, draw: data.draw };
    if (map[type]) document.getElementById('odds-rec').value = map[type].toFixed(2);

    msg.style.cssText = 'display:block;background:rgba(34,197,94,.1);color:#22c55e;border:1px solid rgba(34,197,94,.3)';
    msg.textContent = `✅ Cotes récupérées — ${data.source}`;
    icon.textContent = '✅';
  } catch(e) {
    msg.style.cssText = 'display:block;background:rgba(239,68,68,.1);color:#ef4444;border:1px solid rgba(239,68,68,.3)';
    msg.textContent = `❌ ${e.message}`;
    icon.textContent = '⚡';
    btn.disabled = false;
  }
}

/* ── Dépublier ── */
function depublish() {
  const f = document.getElementById('pro-form');
  const h = document.createElement('input');
  h.type = 'hidden'; h.name = 'publish'; h.value = 'false';
  f.appendChild(h);
  f.submit();
}
</script>

<% if(isEdit && (match.status === 'FINISHED' || match.status === 'finished')) { %>
<div class="card" style="margin-top:1.2rem">
  <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1rem">
    <span style="font-size:1.1rem">🏁</span>
    <div>
      <div style="font-weight:700;font-size:.9rem">Résultat du pronostic</div>
      <div style="font-size:.75rem;color:var(--text-dim)">
        Score final : <strong><%= match.homeTeam %> <%= match.homeScore ?? '?' %> – <%= match.awayScore ?? '?' %> <%= match.awayTeam %></strong>
      </div>
    </div>
    <% if(pro.result === 'WIN') { %>
      <span class="badge badge-ok" style="margin-left:auto;font-size:.82rem;padding:.3rem .75rem">✅ WIN</span>
    <% } else if(pro.result === 'LOSS') { %>
      <span class="badge badge-error" style="margin-left:auto;font-size:.82rem;padding:.3rem .75rem">❌ LOSS</span>
    <% } else { %>
      <span class="badge" style="margin-left:auto;background:var(--surface-d);color:var(--text-dim);font-size:.82rem;padding:.3rem .75rem">— Non défini</span>
    <% } %>
  </div>

  <% if(typeof query !== 'undefined' && query.result_success) { %>
  <div class="alert alert-success" style="margin-bottom:.75rem">✅ Résultat mis à jour.</div>
  <% } %>
  <% if(typeof query !== 'undefined' && query.result_error) { %>
  <div class="alert alert-error" style="margin-bottom:.75rem">❌ <%= query.result_error %></div>
  <% } %>

  <div style="display:flex;gap:.6rem;flex-wrap:wrap">
    <form method="POST" action="/admin/pronostics/result/<%= pro.id %>" style="display:contents">
      <input type="hidden" name="match_id" value="<%= match.id %>">
      <input type="hidden" name="result" value="WIN">
      <button type="submit" class="btn" style="background:#16a34a;color:#fff;border:none;padding:.5rem 1.25rem;border-radius:var(--radius-s);font-weight:700;cursor:pointer<%= pro.result==='WIN'?' box-shadow:0 0 0 3px rgba(22,163,74,.35)':'' %>">
        ✅ Forcer WIN
      </button>
    </form>
    <form method="POST" action="/admin/pronostics/result/<%= pro.id %>" style="display:contents">
      <input type="hidden" name="match_id" value="<%= match.id %>">
      <input type="hidden" name="result" value="LOSS">
      <button type="submit" class="btn" style="background:#dc2626;color:#fff;border:none;padding:.5rem 1.25rem;border-radius:var(--radius-s);font-weight:700;cursor:pointer">
        ❌ Forcer LOSS
      </button>
    </form>
    <% if(pro.result) { %>
    <form method="POST" action="/admin/pronostics/result/<%= pro.id %>" style="display:contents">
      <input type="hidden" name="match_id" value="<%= match.id %>">
      <input type="hidden" name="result" value="null">
      <button type="submit" class="btn btn-outline" style="padding:.5rem 1.25rem;border-radius:var(--radius-s);font-weight:600;cursor:pointer">
        ↺ Réinitialiser
      </button>
    </form>
    <% } %>
  </div>

  <p style="margin-top:.75rem;font-size:.73rem;color:var(--text-dim)">
    Le résultat automatique est calculé depuis le score. Utilisez ces boutons uniquement pour corriger une erreur.
  </p>
</div>
<% } %>

<%- include('layout_bottom') %>
