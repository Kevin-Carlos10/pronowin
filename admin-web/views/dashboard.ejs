<%- include('layout_top', {page:'dashboard'}) %>

<style>
/* ── KPI Cards ─────────────────────────────────────────────────────────────── */
.kpi-grid       { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px,1fr)); gap: 1rem; margin-bottom: 1.25rem; }
.kpi-card       { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem 1.5rem; position: relative; overflow: hidden; transition: transform var(--transition), box-shadow var(--transition); text-decoration: none; color: inherit; display: block; }
.kpi-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); border-color: var(--primary); }
.kpi-card::before { content:''; position:absolute; top:0;left:0;right:0; height:3px; border-radius: var(--radius) var(--radius) 0 0; }
.kpi-card.blue::before   { background: var(--info); }
.kpi-card.orange::before { background: var(--primary); }
.kpi-card.red::before    { background: var(--error); }
.kpi-card.green::before  { background: var(--success); }
.kpi-card.purple::before { background: var(--purple, #7C3AED); }
.kpi-icon  { font-size: 1.5rem; margin-bottom: .5rem; }
.kpi-val   { font-size: 1.9rem; font-weight: 800; line-height: 1; margin-bottom: .25rem; }
.kpi-lbl   { font-size: .78rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: .05em; font-weight: 600; }
.kpi-delta { font-size: .78rem; margin-top: .4rem; font-weight: 500; }
.kpi-delta.up   { color: var(--success); }
.kpi-delta.down { color: var(--error); }
.kpi-delta.neu  { color: var(--text-dim); }

/* ── Alertes intelligentes ─────────────────────────────────────────────────── */
.alerts-list { display: flex; flex-direction: column; gap: .5rem; margin-bottom: 1.25rem; }
.dash-alert  { display: flex; align-items: center; gap: .75rem; padding: .7rem 1rem; border-radius: var(--radius-s); font-size: .83rem; border: 1px solid; }
.dash-alert-icon { font-size: 1.1rem; flex-shrink: 0; }
.dash-alert-text { flex: 1; line-height: 1.4; }
.dash-alert a    { color: inherit; font-weight: 600; text-decoration: underline; }
.dash-alert.danger  { background: rgba(239,68,68,.08);  border-color: rgba(239,68,68,.2);  color: #FCA5A5; }
.dash-alert.warning { background: rgba(245,158,11,.08); border-color: rgba(245,158,11,.2); color: #FCD34D; }
.dash-alert.info    { background: rgba(59,130,246,.08); border-color: rgba(59,130,246,.2); color: #93C5FD; }
.dash-alert.success { background: rgba(34,197,94,.08);  border-color: rgba(34,197,94,.2);  color: #86EFAC; }

/* ── Grilles ───────────────────────────────────────────────────────────────── */
.charts-grid    { display: grid; grid-template-columns: 2fr 1fr; gap: 1rem; margin-bottom: 1rem; }
.charts-row     { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
.bottom-grid    { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
.chart-card     { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; }
.chart-card h3  { font-size: .95rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: .4rem; }
.chart-wrap     { position: relative; }

/* ── Tables ────────────────────────────────────────────────────────────────── */
.dash-table  { width: 100%; border-collapse: collapse; }
.dash-table th { text-align:left; padding: .5rem .75rem; font-size: .72rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid var(--border); white-space: nowrap; }
.dash-table td { padding: .6rem .75rem; border-bottom: 1px solid var(--border); font-size: .83rem; vertical-align: middle; }
.dash-table tr:last-child td { border-bottom: 0; }
.dash-table tr:hover td { background: var(--surface-d); }

/* ── Feed activité ─────────────────────────────────────────────────────────── */
.activity-feed { display: flex; flex-direction: column; gap: 0; }
.activity-item { display: flex; align-items: flex-start; gap: .6rem; padding: .65rem .75rem; border-bottom: 1px solid var(--border); font-size: .8rem; }
.activity-item:last-child { border-bottom: 0; }
.activity-dot  { width: 8px; height: 8px; border-radius: 50%; background: var(--primary); margin-top: .25rem; flex-shrink: 0; }
.activity-body { flex: 1; min-width: 0; }
.activity-action { font-weight: 600; color: var(--text); }
.activity-meta   { color: var(--text-dim); margin-top: .1rem; }
.activity-time   { font-size: .72rem; color: var(--text-dim); white-space: nowrap; flex-shrink: 0; }

/* ── Quick actions ─────────────────────────────────────────────────────────── */
.quick-actions { display: flex; flex-direction: column; gap: .45rem; }
.qa-btn { display: flex; align-items: center; gap: .6rem; padding: .65rem .85rem; background: var(--surface-d); border: 1px solid var(--border); border-radius: var(--radius-s); color: var(--text); text-decoration: none; font-size: .83rem; font-weight: 500; transition: all .15s; cursor: pointer; width: 100%; text-align: left; font-family: inherit; }
.qa-btn:hover  { background: var(--surface-h); border-color: var(--primary); color: var(--primary); transform: translateX(2px); }
.qa-btn-icon   { font-size: 1rem; flex-shrink: 0; }

/* ── Card section header ───────────────────────────────────────────────────── */
.card-header { padding: .9rem 1.25rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.card-header h3 { margin: 0; font-size: .9rem; font-weight: 700; }

/* ── Responsive ────────────────────────────────────────────────────────────── */
@media (max-width: 1100px) { .bottom-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 900px)  { .charts-grid, .charts-row, .bottom-grid { grid-template-columns: 1fr; } }
</style>

<div class="topbar">
  <div>
    <h2>Dashboard</h2>
    <small>Bonjour, <strong><%= adminName %></strong> 👋 — <span id="dash-date" style="color:var(--text-dim)"></span></small>
  </div>
  <div style="display:flex;gap:.5rem;align-items:center">
    <span id="live-indicator" style="font-size:.75rem;color:var(--success);font-weight:600;display:flex;align-items:center;gap:.3rem">
      <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--success);animation:pulse-live 2s ease-in-out infinite"></span> LIVE
    </span>
    <button class="btn btn-outline btn-sm" onclick="refreshAll()" id="refresh-btn">🔄 Actualiser</button>
  </div>
</div>

<!-- ── Alertes intelligentes ──────────────────────────────────────────────── -->
<%
  const _alerts = [];
  const _pendingTotal = pending.total ?? 0;
  const _proofsTotal  = proofs.total  ?? 0;
  if (_pendingTotal >= 10) _alerts.push({ type:'danger',  icon:'🚨', msg:`<strong>${_pendingTotal} transactions</strong> en attente — action requise.`, link:'/admin/transactions', linkTxt:'Traiter →' });
  else if (_pendingTotal >= 3) _alerts.push({ type:'warning', icon:'⚠️', msg:`<strong>${_pendingTotal} transactions</strong> en attente de validation.`, link:'/admin/transactions', linkTxt:'Voir →' });
  if (_proofsTotal >= 5)  _alerts.push({ type:'warning', icon:'👑', msg:`<strong>${_proofsTotal} preuves Premium</strong> en attente de vérification.`, link:'/admin/abonnements', linkTxt:'Vérifier →' });
  if (activeBansCount > 0) _alerts.push({ type:'info',    icon:'🚫', msg:`<strong>${activeBansCount} utilisateur${activeBansCount>1?'s':''}</strong> actuellement banni${activeBansCount>1?'s':''}.`, link:'/admin/bans', linkTxt:'Voir les bans →' });
  if (locals.settings?.maintenanceMode) _alerts.push({ type:'danger', icon:'🔧', msg:'<strong>Mode maintenance actif</strong> — les utilisateurs ne peuvent pas accéder à l\'app.', link:'/admin/settings', linkTxt:'Désactiver →' });
%>
<% if (_alerts.length) { %>
<div class="alerts-list">
  <% _alerts.forEach(al => { %>
  <div class="dash-alert <%= al.type %>">
    <span class="dash-alert-icon"><%= al.icon %></span>
    <span class="dash-alert-text"><%- al.msg %></span>
    <a href="<%= al.link %>" class="btn btn-sm btn-outline" style="flex-shrink:0"><%= al.linkTxt %></a>
  </div>
  <% }) %>
</div>
<% } %>

<!-- ── KPIs ───────────────────────────────────────────────────────────────── -->
<div class="kpi-grid">
  <a href="/admin/users" class="kpi-card blue">
    <div class="kpi-icon">👥</div>
    <div class="kpi-val" id="kpi-users"><%= stats.totalUsers ?? 0 %></div>
    <div class="kpi-lbl">Utilisateurs</div>
    <div class="kpi-delta neu" id="kpi-users-delta">—</div>
  </a>
  <a href="/admin/users?plan=premium" class="kpi-card orange">
    <div class="kpi-icon">👑</div>
    <div class="kpi-val" id="kpi-premium"><%= stats.premiumUsers ?? 0 %></div>
    <div class="kpi-lbl">Membres Premium</div>
    <div class="kpi-delta neu" id="kpi-conv-rate">—</div>
  </a>
  <a href="/admin/transactions" class="kpi-card red">
    <div class="kpi-icon">⏳</div>
    <div class="kpi-val" id="kpi-tx"><%= stats.pendingTx ?? 0 %></div>
    <div class="kpi-lbl">Transactions en attente</div>
    <div class="kpi-delta neu" id="kpi-tx-delta">—</div>
  </a>
  <a href="/admin/pronostics" class="kpi-card green">
    <div class="kpi-icon">⚽</div>
    <div class="kpi-val" id="kpi-prono"><%= stats.publishedToday ?? 0 %></div>
    <div class="kpi-lbl">Pronostics publiés auj.</div>
    <div class="kpi-delta neu" id="kpi-prono-delta">—</div>
  </a>
  <a href="/admin/historique" class="kpi-card purple">
    <div class="kpi-icon">💰</div>
    <div class="kpi-val" id="kpi-revenue">—</div>
    <div class="kpi-lbl">Revenus ce mois</div>
    <div class="kpi-delta neu" id="kpi-revenue-delta">—</div>
  </a>
</div>

<!-- ── Graphiques ─────────────────────────────────────────────────────────── -->
<div class="charts-grid">
  <div class="chart-card">
    <h3>📈 Inscriptions <span style="color:var(--text-dim);font-weight:400;font-size:.82rem">— 14 derniers jours</span></h3>
    <div class="chart-wrap" style="height:200px"><canvas id="chart-signups"></canvas></div>
  </div>
  <div class="chart-card">
    <h3>🎯 Conversion Free → Premium</h3>
    <div class="chart-wrap" style="height:200px;display:flex;align-items:center;justify-content:center">
      <canvas id="chart-conversion" style="max-height:190px"></canvas>
    </div>
  </div>
</div>

<div class="charts-row">
  <div class="chart-card">
    <h3>💳 Dépôts validés <span style="color:var(--text-dim);font-weight:400;font-size:.82rem">— 7 jours (FCFA)</span></h3>
    <div class="chart-wrap" style="height:180px"><canvas id="chart-deposits"></canvas></div>
  </div>
  <div class="chart-card">
    <h3>⚽ Taux de succès pronostics</h3>
    <div class="chart-wrap" style="height:180px;display:flex;align-items:center;justify-content:center">
      <canvas id="chart-pronostics" style="max-height:170px"></canvas>
    </div>
  </div>
</div>

<!-- ── Bas de page : 3 colonnes ───────────────────────────────────────────── -->
<div class="bottom-grid">

  <!-- Transactions en attente -->
  <div class="card" style="padding:0;overflow:hidden">
    <div class="card-header">
      <h3>💰 Dépôts en attente <span style="color:var(--text-dim);font-weight:400">(<%= pending.total %>)</span></h3>
      <a href="/admin/transactions" class="btn btn-sm btn-outline">Tout voir →</a>
    </div>
    <% if(pending.data && pending.data.length > 0){ %>
    <div class="table-wrap"><table class="dash-table">
      <thead><tr><th>Utilisateur</th><th>Montant</th><th>Type</th></tr></thead>
      <tbody>
      <% pending.data.slice(0,5).forEach(tx => { %>
      <tr>
        <td>
          <strong><%= tx.user?.pseudo ?? '—' %></strong>
          <div style="color:var(--text-dim);font-size:.72rem"><%= tx.user?.phoneNumber ?? '' %></div>
        </td>
        <td style="font-weight:700"><%= (tx.amount ?? 0).toLocaleString() %> F</td>
        <td><span class="badge <%= tx.type==='deposit'?'badge-ok':'badge-warn' %>"><%= tx.type==='deposit'?'Dépôt':'Retrait' %></span></td>
      </tr>
      <% }) %>
      </tbody>
    </table></div>
    <% } else { %><p class="empty" style="padding:1.5rem">Aucune demande en attente ✅</p><% } %>
  </div>

  <!-- Activité récente -->
  <div class="card" style="padding:0;overflow:hidden">
    <div class="card-header">
      <h3>📋 Activité récente</h3>
      <a href="/admin/audit" class="btn btn-sm btn-outline">Journal →</a>
    </div>
    <% if(recentLogs && recentLogs.length > 0){ %>
    <div class="activity-feed">
      <% recentLogs.slice(0,8).forEach(log => {
           const _icons = { login:'🔑', logout:'🚪', user_banned:'🚫', user_unbanned:'🔓', login_failed:'⚠️', settings_changed:'⚙️', sub_admin_created:'🔐', sub_admin_deleted:'🗑️' };
           const _icon = _icons[log.action] ?? '•';
           const _since = (() => {
             const ms = Date.now() - new Date(log.timestamp).getTime();
             if (ms < 60000) return 'à l\'instant';
             if (ms < 3600000) return Math.floor(ms/60000) + 'min';
             if (ms < 86400000) return Math.floor(ms/3600000) + 'h';
             return new Date(log.timestamp).toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit'});
           })();
      %>
      <div class="activity-item">
        <div class="activity-dot" style="<%= log.action==='login_failed'?'background:var(--error)':log.action==='user_banned'?'background:var(--error)':log.action==='login'?'background:var(--success)':'' %>"></div>
        <div class="activity-body">
          <div class="activity-action"><%= _icon %> <%= log.adminName %></div>
          <div class="activity-meta"><%= log.target ? log.target.slice(0,40) : log.action %></div>
        </div>
        <div class="activity-time"><%= _since %></div>
      </div>
      <% }) %>
    </div>
    <% } else { %><p class="empty" style="padding:1.5rem">Aucune activité enregistrée.</p><% } %>
  </div>

  <!-- Accès rapides + bans récents -->
  <div style="display:flex;flex-direction:column;gap:1rem">
    <!-- Accès rapides -->
    <div class="card">
      <h3 style="margin-bottom:.75rem;font-size:.9rem">⚡ Accès rapides</h3>
      <div class="quick-actions">
        <% if(hasPerm('users','write')) { %>
        <a href="/admin/users" class="qa-btn"><span class="qa-btn-icon">👥</span> Gérer les utilisateurs</a>
        <% } %>
        <% if(hasPerm('transactions','write')) { %>
        <a href="/admin/transactions" class="qa-btn"><span class="qa-btn-icon">💰</span> Valider les dépôts <% if((pending.total??0)>0){ %><span class="badge badge-err" style="margin-left:auto;font-size:.7rem"><%= pending.total %></span><% } %></a>
        <% } %>
        <% if(hasPerm('abonnements','write')) { %>
        <a href="/admin/abonnements" class="qa-btn"><span class="qa-btn-icon">👑</span> Vérifier preuves Premium <% if((proofs.total??0)>0){ %><span class="badge badge-warn" style="margin-left:auto;font-size:.7rem"><%= proofs.total %></span><% } %></a>
        <% } %>
        <% if(hasPerm('pronostics','write')) { %>
        <a href="/admin/pronostics" class="qa-btn"><span class="qa-btn-icon">⚽</span> Publier un pronostic</a>
        <% } %>
        <% if(hasPerm('notifications','write')) { %>
        <a href="/admin/notifications" class="qa-btn"><span class="qa-btn-icon">📣</span> Envoyer une notification</a>
        <% } %>
        <% if(isMain) { %>
        <a href="/admin/bans" class="qa-btn"><span class="qa-btn-icon">🚫</span> Bannissements <% if(activeBansCount>0){ %><span class="badge badge-err" style="margin-left:auto;font-size:.7rem"><%= activeBansCount %></span><% } %></a>
        <% } %>
      </div>
    </div>

    <!-- Bans récents (si >0) -->
    <% if(activeBansCount > 0 && recentBans && recentBans.length > 0){ %>
    <div class="card" style="padding:0;overflow:hidden">
      <div class="card-header">
        <h3 style="color:var(--error)">🚫 Bans actifs (<%= activeBansCount %>)</h3>
        <a href="/admin/bans" class="btn btn-sm btn-outline">Voir →</a>
      </div>
      <% recentBans.forEach(ban => { %>
      <div style="display:flex;align-items:center;gap:.6rem;padding:.65rem .75rem;border-bottom:1px solid var(--border);font-size:.82rem">
        <div style="width:28px;height:28px;border-radius:50%;background:rgba(239,68,68,.15);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;color:var(--error);flex-shrink:0"><%= (ban.pseudo||'?')[0].toUpperCase() %></div>
        <div style="flex:1;min-width:0">
          <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= ban.pseudo %></div>
          <div style="font-size:.72rem;color:var(--text-dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= ban.reason %></div>
        </div>
        <a href="/admin/users/<%= ban.userId %>" class="btn btn-sm btn-outline" style="flex-shrink:0">→</a>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

</div>

<!-- ── Chart.js ─────────────────────────────────────────────────────────── -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
/* ── Date ── */
document.getElementById('dash-date').textContent =
  new Date().toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });

/* ── Couleurs CSS vars → valeurs réelles ── */
function cssVar(name) {
  return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
}
function hexToRgba(hex, a) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
}

/* ── Config globale Chart.js adaptative ── */
function applyChartDefaults() {
  const gridColor   = cssVar('--border') || '#1E2A42';
  const textColor   = cssVar('--text-dim') || '#8892AA';
  const tooltipBg   = cssVar('--surface') || '#141926';
  const tooltipBdr  = cssVar('--border') || '#1E2A42';
  const tooltipText = cssVar('--text') || '#E2E8F0';
  Chart.defaults.color                               = textColor;
  Chart.defaults.borderColor                         = gridColor;
  Chart.defaults.font.family                         = "'Inter', system-ui, sans-serif";
  Chart.defaults.font.size                           = 11;
  Chart.defaults.plugins.legend.labels.boxWidth      = 10;
  Chart.defaults.plugins.legend.labels.padding       = 14;
  Chart.defaults.plugins.tooltip.backgroundColor     = tooltipBg;
  Chart.defaults.plugins.tooltip.borderColor         = tooltipBdr;
  Chart.defaults.plugins.tooltip.borderWidth         = 1;
  Chart.defaults.plugins.tooltip.titleColor          = tooltipText;
  Chart.defaults.plugins.tooltip.bodyColor           = textColor;
  Chart.defaults.plugins.tooltip.padding             = 10;
}
applyChartDefaults();

/* ── Palette ── */
function palette() {
  const primary = cssVar('--primary') || '#E8541A';
  return {
    blue:   cssVar('--info')    || '#3B82F6',
    orange: primary,
    green:  cssVar('--success') || '#22C55E',
    red:    cssVar('--error')   || '#EF4444',
    purple: '#A78BFA',
    border: cssVar('--border')  || '#1E2A42',
  };
}

let chartSignups, chartConv, chartDeposits, chartPronos;

function last14Days() {
  const days = [];
  for (let i = 13; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate() - i);
    days.push(d.toLocaleDateString('fr-FR', { day:'2-digit', month:'2-digit' }));
  }
  return days;
}
function last7Days() { return last14Days().slice(7); }

/* ── Build charts ── */
function buildSignupsChart(data) {
  if (chartSignups) chartSignups.destroy();
  const P = palette();
  const ctx = document.getElementById('chart-signups')?.getContext('2d');
  if (!ctx) return;
  const g = ctx.createLinearGradient(0,0,0,200);
  g.addColorStop(0, hexToRgba(P.blue, .35));
  g.addColorStop(1, hexToRgba(P.blue, .02));
  chartSignups = new Chart(ctx, {
    type: 'line',
    data: { labels: data.labels ?? last14Days(), datasets: [{ label:'Inscriptions', data: data.values ?? [], borderColor: P.blue, backgroundColor: g, fill:true, tension:.4, pointRadius:3, pointBackgroundColor: P.blue }] },
    options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false } }, scales: { x:{ grid:{display:false}, ticks:{maxTicksLimit:7} }, y:{ grid:{color: P.border}, beginAtZero:true, ticks:{precision:0} } } }
  });
}

function buildConversionChart(free, premium) {
  if (chartConv) chartConv.destroy();
  const P = palette();
  const ctx = document.getElementById('chart-conversion')?.getContext('2d');
  if (!ctx) return;
  chartConv = new Chart(ctx, {
    type: 'doughnut',
    data: { labels:['Free','Premium'], datasets:[{ data:[Math.max(free,0),Math.max(premium,0)], backgroundColor:[hexToRgba(P.blue,.25),hexToRgba(P.orange,.6)], borderColor:[P.blue,P.orange], borderWidth:1.5, hoverOffset:6 }] },
    options: { responsive:true, maintainAspectRatio:false, cutout:'68%', plugins:{ legend:{position:'bottom'}, tooltip:{ callbacks:{ label: c => ` ${c.label} : ${c.raw} (${Math.round(c.raw/((free+premium)||1)*100)}%)` } } } }
  });
}

function buildDepositsChart(data) {
  if (chartDeposits) chartDeposits.destroy();
  const P = palette();
  const ctx = document.getElementById('chart-deposits')?.getContext('2d');
  if (!ctx) return;
  const g = ctx.createLinearGradient(0,0,0,180);
  g.addColorStop(0, hexToRgba(P.green,.45));
  g.addColorStop(1, hexToRgba(P.green,.03));
  chartDeposits = new Chart(ctx, {
    type: 'bar',
    data: { labels: data.labels ?? last7Days(), datasets:[{ label:'FCFA validés', data: data.values ?? [], backgroundColor: g, borderColor: P.green, borderWidth:1.5, borderRadius:5 }] },
    options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{ x:{grid:{display:false}}, y:{grid:{color:P.border}, beginAtZero:true, ticks:{callback: v => v>=1000?(v/1000)+'k':v}} } }
  });
}

function buildPronosticsChart(won, lost, pending) {
  if (chartPronos) chartPronos.destroy();
  const P = palette();
  const ctx = document.getElementById('chart-pronostics')?.getContext('2d');
  if (!ctx) return;
  chartPronos = new Chart(ctx, {
    type: 'doughnut',
    data: { labels:['Gagnés','Perdus','En cours'], datasets:[{ data:[Math.max(won,0),Math.max(lost,0),Math.max(pending,0)], backgroundColor:[hexToRgba(P.green,.55),hexToRgba(P.red,.45),hexToRgba(P.orange,.35)], borderColor:[P.green,P.red,P.orange], borderWidth:1.5, hoverOffset:6 }] },
    options: { responsive:true, maintainAspectRatio:false, cutout:'65%', plugins:{ legend:{position:'bottom'}, tooltip:{ callbacks:{ label: c => { const t=won+lost+pending; return ` ${c.label} : ${c.raw} (${Math.round(c.raw/(t||1)*100)}%)`; } } } } }
  });
}

/* ── Flash KPI ── */
function flashUpdate(id, val, format) {
  if (val === null || val === undefined) return;
  const el = document.getElementById(id);
  if (!el) return;
  const display = format ? format(val) : String(val);
  if (el.textContent === display) return;
  el.style.transition = 'none';
  el.style.color = 'var(--primary)';
  el.textContent = display;
  setTimeout(() => { el.style.transition = ''; el.style.color = ''; }, 1500);
}

/* ── Chargement données ── */
async function loadCharts() {
  const btn = document.getElementById('refresh-btn');
  if (btn) { btn.disabled = true; btn.textContent = '⏳'; }

  try {
    const [signupsRes, depositsRes, pronosticsRes] = await Promise.allSettled([
      fetch('/admin/api/stats/signups?days=14').then(r => r.json()),
      fetch('/admin/api/stats/deposits?days=7').then(r => r.json()),
      fetch('/admin/api/stats/pronostics').then(r => r.json()),
    ]);

    const signups = signupsRes.status === 'fulfilled' ? signupsRes.value : {};
    buildSignupsChart(signups);
    if (signups.newThisWeek !== undefined) {
      document.getElementById('kpi-users-delta').textContent = `+${signups.newThisWeek} cette semaine`;
      document.getElementById('kpi-users-delta').className = 'kpi-delta up';
    }

    const totalU   = parseInt(document.getElementById('kpi-users')?.textContent.replace(/\s/g,'')) || 0;
    const premiumU = parseInt(document.getElementById('kpi-premium')?.textContent.replace(/\s/g,'')) || 0;
    buildConversionChart(totalU - premiumU, premiumU);
    if (totalU > 0) {
      const rate = Math.round(premiumU / totalU * 100);
      document.getElementById('kpi-conv-rate').textContent = `Taux conversion : ${rate}%`;
      document.getElementById('kpi-conv-rate').className   = rate > 10 ? 'kpi-delta up' : 'kpi-delta neu';
    }

    const deposits = depositsRes.status === 'fulfilled' ? depositsRes.value : {};
    buildDepositsChart(deposits);
    if (deposits.totalThisMonth !== undefined) {
      document.getElementById('kpi-revenue').textContent       = (deposits.totalThisMonth ?? 0).toLocaleString() + ' F';
      const vs = deposits.vsLastMonth;
      document.getElementById('kpi-revenue-delta').textContent = vs !== undefined ? (vs >= 0 ? '+' : '') + vs + '% vs mois passé' : '—';
      document.getElementById('kpi-revenue-delta').className   = vs > 0 ? 'kpi-delta up' : vs < 0 ? 'kpi-delta down' : 'kpi-delta neu';
    }

    const pronos = pronosticsRes.status === 'fulfilled' ? pronosticsRes.value : {};
    buildPronosticsChart(pronos.won ?? 0, pronos.lost ?? 0, pronos.pending ?? 0);
    if (pronos.won !== undefined && pronos.lost !== undefined) {
      const total = pronos.won + pronos.lost;
      const rate  = total > 0 ? Math.round(pronos.won / total * 100) : 0;
      document.getElementById('kpi-prono-delta').textContent = `Taux de réussite : ${rate}%`;
      document.getElementById('kpi-prono-delta').className   = rate >= 60 ? 'kpi-delta up' : rate >= 40 ? 'kpi-delta neu' : 'kpi-delta down';
    }

  } catch(e) {
    if (typeof showToast === 'function') showToast('Erreur chargement graphiques', 'error');
  }

  if (btn) { btn.disabled = false; btn.textContent = '🔄 Actualiser'; }
}

function refreshAll() {
  applyChartDefaults(); // Recalcule les couleurs au cas où le thème a changé
  loadCharts();
}

loadCharts();

/* ── SSE temps réel ── */
window.addEventListener('sseKpis', function(e) {
  const d = e.detail;
  if (d.users_total    != null) flashUpdate('kpi-users',   d.users_total);
  if (d.tx_pending     != null) flashUpdate('kpi-tx',      d.tx_pending);
  if (d.proofs_pending != null) flashUpdate('kpi-proofs',  d.proofs_pending);
});

/* ── Reconstruire les charts si le thème change ── */
document.documentElement.addEventListener && (function() {
  const obs = new MutationObserver(() => { applyChartDefaults(); refreshAll(); });
  obs.observe(document.documentElement, { attributes:true, attributeFilter:['class','data-accent'] });
})();
</script>

