/* ═══════════════════════════════════════════════════════════════
   API OFFLINE DETECTION
═══════════════════════════════════════════════════════════════ */
(function detectOffline() {
  let _shown = false;
  window.addEventListener('offline', () => {
    if (!_shown) {
      _shown = true;
