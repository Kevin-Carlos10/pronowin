<script>
/* ═══════════════════════════════════════════════════════════════
   SIDEBAR MOBILE
═══════════════════════════════════════════════════════════════ */
function toggleSidebar() {
  const s = document.getElementById('sidebar');
  const o = document.getElementById('sidebar-overlay');
  const open = s.classList.toggle('open');
  o.classList.toggle('open', open);
  document.body.style.overflow = open ? 'hidden' : '';
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-overlay').classList.remove('open');
  document.body.style.overflow = '';
}
// Fermer la sidebar sur resize > 900px
window.addEventListener('resize', () => {
  if (window.innerWidth > 900) closeSidebar();
});

/* ── Swipe pour fermer la sidebar (mobile) ── */
(function initSwipe() {
  let startX = 0, startY = 0, dragging = false;
  const THRESHOLD = 60; // pixels minimum pour déclencher

  document.addEventListener('touchstart', function(e) {
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
    dragging = true;
  }, { passive: true });

  document.addEventListener('touchend', function(e) {
    if (!dragging) return;
    dragging = false;
    const dx = e.changedTouches[0].clientX - startX;
    const dy = e.changedTouches[0].clientY - startY;
    // Swipe horizontal seulement (ignore si trop vertical)
    if (Math.abs(dx) < THRESHOLD || Math.abs(dy) > Math.abs(dx) * 0.8) return;
    const sidebar = document.getElementById('sidebar');
    if (dx < 0 && sidebar?.classList.contains('open')) {
      // Swipe gauche → fermer sidebar
      closeSidebar();
    } else if (dx > 0 && startX < 24 && !(sidebar?.classList.contains('open'))) {
      // Swipe droite depuis le bord gauche → ouvrir sidebar
      toggleSidebar();
    }
  }, { passive: true });
})();

/* ── data-label automatique sur les <td> pour le responsive mobile ── */
(function labelTableCells() {
  document.querySelectorAll('table').forEach(function(table) {
    const headers = Array.from(table.querySelectorAll('thead th')).map(function(th) {
      return th.textContent.trim().replace(/[▲▼]/g, '').trim();
    });
    table.querySelectorAll('tbody tr').forEach(function(row) {
      Array.from(row.querySelectorAll('td')).forEach(function(td, i) {
        if (headers[i] && !td.hasAttribute('data-label')) {
          td.setAttribute('data-label', headers[i]);
        }
      });
    });
  });
})();

/* ── Bottom nav badge sync ── */
function _syncBottomNavBadge(id, count) {
  const el = document.getElementById(id);
  if (!el) return;
  if (count > 0) { el.textContent = count > 99 ? '99+' : count; el.classList.add('visible'); }
  else           { el.classList.remove('visible'); }
}

/* ═══════════════════════════════════════════════════════════════
   TOASTS
═══════════════════════════════════════════════════════════════ */
function showToast(msg, type = 'info', duration = 4000) {
  const container = document.getElementById('toast-container');
  const icons = { success: '✅', error: '❌', info: 'ℹ️' };
  const toast = document.createElement('div');
  toast.className = `toast toast-${type}`;
  toast.innerHTML = `<span>${icons[type] || 'ℹ️'}</span><span>${msg}</span>`;
  container.appendChild(toast);
  setTimeout(() => {
    toast.classList.add('out');
    setTimeout(() => toast.remove(), 250);
  }, duration);
}
// Afficher les alertes de page en toast au chargement
window.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.alert').forEach(el => {
    const type = el.classList.contains('alert-success') ? 'success'
               : el.classList.contains('alert-error')   ? 'error' : 'info';
    showToast(el.textContent.trim(), type);
  });
});

/* ═══════════════════════════════════════════════════════════════
   CONFIRM DIALOG
═══════════════════════════════════════════════════════════════ */
let _confirmCallback = null;

function askConfirm({ icon = '⚠️', title = 'Confirmer', msg = 'Êtes-vous sûr ?', btnLabel = 'Confirmer', btnClass = 'btn-primary', onConfirm }) {
  document.getElementById('confirm-icon').textContent  = icon;
  document.getElementById('confirm-title').textContent = title;
  document.getElementById('confirm-msg').textContent   = msg;
  const btn = document.getElementById('confirm-ok-btn');
  btn.textContent = btnLabel;
  btn.className   = `btn ${btnClass}`;
  _confirmCallback = onConfirm;
  document.getElementById('confirm-overlay').classList.add('open');
}
function closeConfirm() {
  document.getElementById('confirm-overlay').classList.remove('open');
  _confirmCallback = null;
}
function submitConfirm() {
  closeConfirm();
  if (_confirmCallback) _confirmCallback();
}
// Fermer sur Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeConfirm();
});

/* ═══════════════════════════════════════════════════════════════
   FETCH WRAPPER — gestion d'erreurs centralisée
═══════════════════════════════════════════════════════════════ */
async function apiFetch(url, opts = {}) {
  const controller = new AbortController();
  const timer      = setTimeout(() => controller.abort(), 12000);
  try {
    const r = await fetch(url, { ...opts, signal: controller.signal });
    clearTimeout(timer);
    if (r.status === 401) { window.location.href = '/admin/login?expired=1'; return null; }
    if (!r.ok) {
      const data = await r.json().catch(() => ({}));
      throw new Error(data.message ?? data.error ?? `Erreur ${r.status}`);
    }
    return await r.json();
  } catch (e) {
    clearTimeout(timer);
    if (e.name === 'AbortError') throw new Error('Délai dépassé — le serveur ne répond pas.');
    throw e;
  }
}

