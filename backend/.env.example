# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── Version checker ───────────────────────────────────────────────────────────
APP_MIN_VERSION=1.0.0
APP_LATEST_VERSION=1.0.0
APP_FORCE_UPDATE=false
APP_UPDATE_MESSAGE=Une nouvelle version de PronoWin est disponible.

# Base de données PostgreSQL
DATABASE_URL="postgresql://pronowin_user:PASSWORD@localhost:5432/pronowin_db"

# JWT
JWT_SECRET=CHANGE_THIS_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_KEY
JWT_REFRESH_EXPIRES_IN=30d

# WhatsApp OTP (Meta Cloud API)
# Obtenir sur: https://developers.facebook.com → Mon application → WhatsApp → Configuration
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_TEMPLATE_NAME=pronowin_otp
WHATSAPP_TEMPLATE_LANG=fr

# Paiement CinetPay (Mobile Money)
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_site_id

# Stripe (Carte bancaire)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY

# 1xBet Affiliation
XBET_AFFILIATE_ID=your_affiliate_id
XBET_API_KEY=your_api_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
